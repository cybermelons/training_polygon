<root>
    <styles>
        <include src="file://{resources}/styles/custom_game/mainmenu_v2.css" />
        <include src="file://{resources}/styles/custom_game/menu2snippets/gamemodes_hud/dodge/dodge.css" />
    </styles>
    <scripts>
        <include src="file://{resources}/scripts/custom_game/menu2snippets/gamemodes_hud/dodge/dodge.js" />
    </scripts>
    <Panel class="Col">
        <Label class="menu_button_label" text="dodge"/>
        <Label class="embeedingContentLabel" text="#timingType"/>
        <Panel id="dodgeTypes" class="RowNoFill">
            
        </Panel>
        <Label text="#manta_options"/>
        <Panel class="RowNoFill">
            <Panel class="ColNoFill">
                <ToggleButton checked="true" id="yashaKayaToggle" class="customCheckbox" text="#menuYashaKaya" />
            
                <ToggleButton checked="true" id="mantaShuffle" class="customCheckbox" text="#shuffleMode" />
                <ToggleButton checked="false" id="hardcoreMode" class="customCheckbox" text="#hardcoreMode" />
                <ToggleButton checked="false" id="cancelAnimToggle" class="customCheckbox" text="#animationCancelMode" />
            </Panel>
            <Panel class="ColNoFill">
                <ToggleButton checked="true" id="yashaKayaPlayerToggle" class="customCheckbox" text="#menuYashaKayaPlayer" />
                <Panel id="stormTimeSetting" class="stormEvadeSetting RowNoFill">
                    <Label class="settingLabel" text="#stormEvadeSetting"/>
                    <Panel id="stormEvadeNumberSwitcher"/>
                </Panel>
            </Panel>
            <Panel class="ColNoFill"/>
        </Panel>
        <!-- <ToggleButton checked="true" id="timebarToggle" class="customCheckbox" text="#menuTimebar" /> -->
        
        <Label text="#menuSkills"/>
        <Panel class="RowNoFill">
            <Button class="menu_button normal_button buttons" id="selectAll" onactivate="selectAllSkills()">
                <Label text="#skillsAll"/>
            </Button>
            <Button class="menu_button normal_button buttons" id="unmarkAll" onactivate="unmarkAllSkills()">
                <Label text="#skillsNone"/>
            </Button>
        </Panel>
        <Panel class="RowNoFill">
            <Panel id="dodgeSpellContainer">

            </Panel>
        </Panel>
        <Panel class="RowNoFill">
            <Button class="menu_button mode_play" id="menu_play" onactivate="startGame()">
				<Label class="mode_play_label" id="menu_play_label" text="Play"/>
            </Button>
            <Label id="errorMsg"></Label>
        </Panel> 
    </Panel>
</root>